{
  "name": "pvp-platform",
  "version": "2.0.0",
  "description": "Skill Arena - PvP Game Platform",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npx prisma generate && tsc && cd client && npm install && npm run build",
    "start": "npx prisma migrate deploy && node dist/server.js",
    "seed": "tsx src/db/seed.ts",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "fastify": "^4.26.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.1",
    "socket.io": "^4.7.4",
    "dotenv": "^16.4.1",
    "@prisma/client": "^5.9.1",
    "jsonwebtoken": "^9.0.2",
    "axios": "^1.6.7"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "@types/node": "^20.11.5",
    "@types/jsonwebtoken": "^9.0.5",
    "prisma": "^5.9.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
